{
  "expo": {
    "name": "Neon",
    "slug": "neon",
    "version": "0.0.2",
    "orientation": "portrait",
    "android": {
      "package": "io.cityofzion.neon",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "src/assets/ic_launcher_foreground.png",
        "backgroundColor": "#1f2b2d"
      }
    },
    "ios": {
      "infoPlist": {
        "NSFaceIDUsageDescription": "This app uses face ID to authenticate the user when dealing with sensitive transactions.",
        "requireFullScreen": true
      },
      "bundleIdentifier": "io.cityofzion.neon"
    },
    "splash": {
      "image": "src/assets/splash-darker.png",
      "resizeMode": "cover",
      "backgroundColor": "#1f2830"
    },
    "icon": "src/assets/ic_launcher.png",
    "primaryColor": "#4cffb3",
    "assetBundlePatterns": ["**/*"],
    "packagerOpts": {
      "config": "metro.config.js",
      "sourceExts": ["expo.ts", "expo.tsx", "expo.js", "expo.jsx", "ts", "tsx", "js", "jsx", "json", "wasm", "svg"]
    }
  }
}
