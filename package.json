{
  "private": true,
  "name": "neon-wallet-mobile",
  "version": "1.2.6",
  "scripts": {
    "serve": "cross-env MODE=dev expo start --clear",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "expo start --web",
    "start": "expo start --dev-client",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "ts-build": "tsc -b",
    "android-release": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/build/intermediates/res/merged/release/ && rm -rf android/app/src/main/res/drawable-* && rm -rf android/app/src/main/res/raw/* && cd android && ./gradlew assembleRelease && cd ..",
    "e2e:ios": "detox test -c ios.sim.release --artifacts-location=e2e/screenshots --take-screenshots=all",
    "e2e:android": "detox test -c android.emu.release --artifacts-location=e2e/screenshots --take-screenshots=all",
    "build:ios": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios",
    "fix:dependencies": "expo doctor --fix-dependencies",
    "ota:production": "cross-env CHANNEL=production yarn prebuild:android && eas update --channel=production -p android && cross-env CHANNEL=production yarn prebuild:ios && eas update --channel=production -p ios && eas logout",
    "ota:staging": "cross-env CHANNEL=staging yarn prebuild:android && eas update --channel=staging -p android && cross-env CHANNEL=staging yarn prebuild:ios && eas update --channel=staging -p ios && eas logout",
    "ota:beta": "cross-env CHANNEL=beta yarn prebuild:android && eas update --channel=beta -p android && cross-env CHANNEL=beta yarn prebuild:ios && eas update --channel=beta -p ios && eas logout",
    "ota:preview": "cross-env CHANNEL=preview yarn prebuild:android && eas update --channel=preview -p android && cross-env CHANNEL=preview yarn prebuild:ios && eas update --channel=preview -p ios && eas logout",
    "prebuild:android": "cross-env PLATFORM=android eas build:configure -p android",
    "prebuild:ios": "cross-env PLATFORM=ios eas build:configure -p ios"
  },
  "dependencies": {
