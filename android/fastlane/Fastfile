# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

platform :android do
  desc "Runs all the tests"

  desc "Submit a new Beta Build"
  lane :beta do
    releaseFilePath = File.join(Dir.pwd, "neon.jks")
    store_password = ENV['ANDROID_STORE_PASS']
    key_password = ENV['ANDROID_KEY_PASS']
    key_alias = ENV['ANDROID_KEY_ALIAS']

    current_version_beta = google_play_track_version_codes(
      track: 'Group Beta',
      json_key: './key.json'
    )

    current_version_staging = google_play_track_version_codes(
      track: 'Group Staging',
      json_key: './key.json'
    )

    current_version_production = google_play_track_version_codes(
      json_key: './key.json'
    )

    current_version = [current_version_beta, current_version_staging, current_version_production].max()[0]

    new_current_version = current_version + 1

    android_set_version_code(
      version_code: new_current_version
    )

    android_set_version_name(
      version_name: '1.0.46b' + String(new_current_version)
    )

    gradle(
      task: 'clean'
    )
   
    gradle(
      task: 'assemble',
      build_type: 'Release',
      print_command: false,
      properties: {
        "android.injected.signing.store.file" => releaseFilePath,
        "android.injected.signing.store.password" => store_password,
        "android.injected.signing.key.alias" => key_alias,
        "android.injected.signing.key.password" => key_password,
      }
    )
    upload_to_play_store(
      track: 'Group Beta'
    )
    # sh "your_script.sh"
    # You can also use other beta testing services here
  end

  desc "Submit a new Staging Build"
  lane :staging do
    releaseFilePath = File.join(Dir.pwd, "neon.jks")
    store_password = ENV['ANDROID_STORE_PASS']
    key_password = ENV['ANDROID_KEY_PASS']
    key_alias = ENV['ANDROID_KEY_ALIAS']

    current_version_beta = google_play_track_version_codes(
      track: 'Group Beta',
      json_key: './key.json'
    )

    current_version_staging = google_play_track_version_codes(
      track: 'Group Staging',
      json_key: './key.json'
    )

    current_version_production = google_play_track_version_codes(
      json_key: './key.json'
    )

    current_version = [current_version_beta, current_version_staging, current_version_production].max()[0]

    new_current_version = current_version + 1

    gradle(task: 'clean')

    android_set_version_code(
      version_code: new_current_version
    )

    android_set_version_name(
      version_name: '1.0.46b' + String(new_current_version)
    )
   
    gradle(
      task: 'assemble',
      flags: '--debug',
      build_type: 'Release',
      print_command: false,
      properties: {
        "android.injected.signing.store.file" => releaseFilePath,
        "android.injected.signing.store.password" => store_password,
        "android.injected.signing.key.alias" => key_alias,
        "android.injected.signing.key.password" => key_password,
      }
    )
    upload_to_play_store(
      track: 'Group Staging'
    )
    # sh "your_script.sh"
    # You can also use other beta testing services here
  end

  lane :check_version do
   releaseFilePath = File.join(Dir.pwd, "neon.jks")
    store_password = ENV['ANDROID_STORE_PASS']
    key_password = ENV['ANDROID_KEY_PASS']
    key_alias = ENV['ANDROID_KEY_ALIAS']

    current_version_beta = google_play_track_version_codes(
      track: 'Group Beta',
      json_key: './key.json'
    )

    current_version_staging = google_play_track_version_codes(
      track: 'Group Staging',
      json_key: './key.json'
    )

    current_version_production = google_play_track_version_codes(
      json_key: './key.json'
    )

    current_version = [current_version_beta, current_version_staging, current_version_production].max()

    puts current_version[0].is_a? Integer

  end

  lane :deploy do

    gradle(task: 'clean')
    
    current_version = google_play_track_version_codes(
      track: 'Group Beta',
      json_key: './key.json'
    )
    new_current_version = current_version[0]

    android_set_version_code(
      version_code: new_current_version
    )

    android_set_version_name(
      version_name: '1.0.46b' + String(new_current_version)
    )

    upload_to_play_store(
      track: 'Group Staging',
      version_code: new_current_version,
      skip_upload_changelogs: true
    )
  end

  lane :gradle_test do
    releaseFilePath = File.join(Dir.pwd, "neon.jks")
    store_password = ENV['ANDROID_STORE_PASS']
    key_password = ENV['ANDROID_KEY_PASS']
    key_alias = ENV['ANDROID_KEY_ALIAS']

    current_version_beta = google_play_track_version_codes(
      track: 'Group Beta',
      json_key: './key.json'
    )

    current_version_staging = google_play_track_version_codes(
      track: 'Group Staging',
      json_key: './key.json'
    )

    current_version_production = google_play_track_version_codes(
      json_key: './key.json'
    )

    current_version = [current_version_beta, current_version_staging, current_version_production].max()[0]

    new_current_version = current_version + 1

    android_set_version_code(
      version_code: new_current_version
    )

    android_set_version_name(
      version_name: '1.0.46b' + String(new_current_version)
    )
    
    gradle(
      task: 'clean'
    )

    gradle(
      task: 'assemble',
      build_type: 'Release',
      print_command: false,
      properties: {
        "android.injected.signing.store.file" => releaseFilePath,
        "android.injected.signing.store.password" => store_password,
        "android.injected.signing.key.alias" => key_alias,
        "android.injected.signing.key.password" => key_password,
      }
    )
  end
end
